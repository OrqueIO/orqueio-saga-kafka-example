<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_1"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:error id="Error_CallKO" name="CALL_KO" errorCode="CALL_KO"/>

  <bpmn:process id="travel-saga" name="Travel Booking Saga - Async Orchestration" isExecutable="true"
                camunda:historyTimeToLive="P180D">

    <!-- ==================== START ==================== -->
    <bpmn:startEvent id="StartEvent" name="Booking Received">
      <bpmn:outgoing>Flow_ToCallFlight</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- ==================== STEP 1: BOOK FLIGHT (Call Worker) ==================== -->
    <bpmn:callActivity id="CallFlight" name="Call Flight Worker"
                       calledElement="callworker">
      <bpmn:extensionElements>
        <camunda:in variables="all"/>
        <camunda:in sourceExpression="${'saga.flight.command'}" target="commandTopic"/>
        <camunda:in sourceExpression="${'EXECUTE'}" target="workerAction"/>
        <camunda:out variables="all"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToCallFlight</bpmn:incoming>
      <bpmn:outgoing>Flow_ToCallHotel</bpmn:outgoing>
    </bpmn:callActivity>

    <bpmn:boundaryEvent id="BoundaryError_Flight" attachedToRef="CallFlight">
      <bpmn:outgoing>Flow_FlightFailed</bpmn:outgoing>
      <bpmn:errorEventDefinition errorRef="Error_CallKO"/>
    </bpmn:boundaryEvent>

    <!-- ==================== STEP 2: BOOK HOTEL (Call Worker) ==================== -->
    <bpmn:callActivity id="CallHotel" name="Call Hotel Worker"
                       calledElement="callworker">
      <bpmn:extensionElements>
        <camunda:in variables="all"/>
        <camunda:in sourceExpression="${'saga.hotel.command'}" target="commandTopic"/>
        <camunda:in sourceExpression="${'EXECUTE'}" target="workerAction"/>
        <camunda:out variables="all"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToCallHotel</bpmn:incoming>
      <bpmn:outgoing>Flow_ToCallCar</bpmn:outgoing>
    </bpmn:callActivity>

    <bpmn:boundaryEvent id="BoundaryError_Hotel" attachedToRef="CallHotel">
      <bpmn:outgoing>Flow_HotelFailed</bpmn:outgoing>
      <bpmn:errorEventDefinition errorRef="Error_CallKO"/>
    </bpmn:boundaryEvent>

    <!-- ==================== STEP 3: RENT CAR (Call Worker) ==================== -->
    <bpmn:callActivity id="CallCar" name="Call Car Worker"
                       calledElement="callworker">
      <bpmn:extensionElements>
        <camunda:in variables="all"/>
        <camunda:in sourceExpression="${'saga.car.command'}" target="commandTopic"/>
        <camunda:in sourceExpression="${'EXECUTE'}" target="workerAction"/>
        <camunda:out variables="all"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToCallCar</bpmn:incoming>
      <bpmn:outgoing>Flow_ToEndSuccess</bpmn:outgoing>
    </bpmn:callActivity>

    <bpmn:boundaryEvent id="BoundaryError_Car" attachedToRef="CallCar">
      <bpmn:outgoing>Flow_CarFailed</bpmn:outgoing>
      <bpmn:errorEventDefinition errorRef="Error_CallKO"/>
    </bpmn:boundaryEvent>

    <!-- ==================== END SUCCESS ==================== -->
    <bpmn:endEvent id="End_Success" name="Trip Booked Successfully">
      <bpmn:incoming>Flow_ToEndSuccess</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ==================== COMPENSATION: FLIGHT FAILED ==================== -->
    <bpmn:endEvent id="End_FlightFailed" name="Flight Unavailable">
      <bpmn:incoming>Flow_FlightFailed</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ==================== COMPENSATION: HOTEL FAILED → Cancel Flight ==================== -->
    <bpmn:serviceTask id="CancelFlight_FromHotel" name="Cancel Flight"
                      camunda:delegateExpression="${messageProducer}">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="commandTopic">saga.flight.command</camunda:inputParameter>
          <camunda:inputParameter name="workerAction">COMPENSATE</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_HotelFailed</bpmn:incoming>
      <bpmn:outgoing>Flow_ToEndHotelFailed</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_HotelFailed" name="Hotel Unavailable - Flight Cancelled">
      <bpmn:incoming>Flow_ToEndHotelFailed</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ==================== COMPENSATION: CAR FAILED → Cancel Hotel → Cancel Flight ==================== -->
    <bpmn:serviceTask id="CancelHotel" name="Cancel Hotel"
                      camunda:delegateExpression="${messageProducer}">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="commandTopic">saga.hotel.command</camunda:inputParameter>
          <camunda:inputParameter name="workerAction">COMPENSATE</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_CarFailed</bpmn:incoming>
      <bpmn:outgoing>Flow_ToCancelFlight_FromCar</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="CancelFlight_FromCar" name="Cancel Flight"
                      camunda:delegateExpression="${messageProducer}">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="commandTopic">saga.flight.command</camunda:inputParameter>
          <camunda:inputParameter name="workerAction">COMPENSATE</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToCancelFlight_FromCar</bpmn:incoming>
      <bpmn:outgoing>Flow_ToEndCarFailed</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_CarFailed" name="Car Unavailable - Hotel &amp; Flight Cancelled">
      <bpmn:incoming>Flow_ToEndCarFailed</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ==================== SEQUENCE FLOWS ==================== -->
    <bpmn:sequenceFlow id="Flow_ToCallFlight" sourceRef="StartEvent" targetRef="CallFlight"/>
    <bpmn:sequenceFlow id="Flow_FlightFailed" sourceRef="BoundaryError_Flight" targetRef="End_FlightFailed"/>
    <bpmn:sequenceFlow id="Flow_ToCallHotel" sourceRef="CallFlight" targetRef="CallHotel"/>
    <bpmn:sequenceFlow id="Flow_HotelFailed" sourceRef="BoundaryError_Hotel" targetRef="CancelFlight_FromHotel"/>
    <bpmn:sequenceFlow id="Flow_ToEndHotelFailed" sourceRef="CancelFlight_FromHotel" targetRef="End_HotelFailed"/>
    <bpmn:sequenceFlow id="Flow_ToCallCar" sourceRef="CallHotel" targetRef="CallCar"/>
    <bpmn:sequenceFlow id="Flow_CarFailed" sourceRef="BoundaryError_Car" targetRef="CancelHotel"/>
    <bpmn:sequenceFlow id="Flow_ToCancelFlight_FromCar" sourceRef="CancelHotel" targetRef="CancelFlight_FromCar"/>
    <bpmn:sequenceFlow id="Flow_ToEndCarFailed" sourceRef="CancelFlight_FromCar" targetRef="End_CarFailed"/>
    <bpmn:sequenceFlow id="Flow_ToEndSuccess" sourceRef="CallCar" targetRef="End_Success"/>

  </bpmn:process>

  <!-- ==================== DIAGRAM ==================== -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="travel-saga">

      <!-- ===== HAPPY PATH (row 1, y~200) ===== -->
      <bpmndi:BPMNShape id="StartEvent_di" bpmnElement="StartEvent">
        <dc:Bounds x="80" y="202" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CallFlight_di" bpmnElement="CallFlight">
        <dc:Bounds x="200" y="180" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CallHotel_di" bpmnElement="CallHotel">
        <dc:Bounds x="420" y="180" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CallCar_di" bpmnElement="CallCar">
        <dc:Bounds x="640" y="180" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_Success_di" bpmnElement="End_Success">
        <dc:Bounds x="822" y="202" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- ===== BOUNDARY ERROR EVENTS ===== -->
      <bpmndi:BPMNShape id="BoundaryError_Flight_di" bpmnElement="BoundaryError_Flight">
        <dc:Bounds x="232" y="242" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BoundaryError_Hotel_di" bpmnElement="BoundaryError_Hotel">
        <dc:Bounds x="452" y="242" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BoundaryError_Car_di" bpmnElement="BoundaryError_Car">
        <dc:Bounds x="672" y="242" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- ===== FLIGHT FAILURE (row 2 left, y~370) ===== -->
      <bpmndi:BPMNShape id="End_FlightFailed_di" bpmnElement="End_FlightFailed">
        <dc:Bounds x="232" y="370" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- ===== HOTEL FAILURE: Cancel Flight → End (row 2 center, y~370) ===== -->
      <bpmndi:BPMNShape id="CancelFlight_FromHotel_di" bpmnElement="CancelFlight_FromHotel">
        <dc:Bounds x="420" y="350" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_HotelFailed_di" bpmnElement="End_HotelFailed">
        <dc:Bounds x="582" y="372" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- ===== CAR FAILURE: Cancel Hotel → Cancel Flight → End (row 2-3 right) ===== -->
      <bpmndi:BPMNShape id="CancelHotel_di" bpmnElement="CancelHotel">
        <dc:Bounds x="700" y="350" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CancelFlight_FromCar_di" bpmnElement="CancelFlight_FromCar">
        <dc:Bounds x="700" y="490" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_CarFailed_di" bpmnElement="End_CarFailed">
        <dc:Bounds x="872" y="512" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- ===== EDGES: Happy path ===== -->
      <bpmndi:BPMNEdge id="Flow_ToCallFlight_di" bpmnElement="Flow_ToCallFlight">
        <di:waypoint x="116" y="220"/>
        <di:waypoint x="200" y="220"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToCallHotel_di" bpmnElement="Flow_ToCallHotel">
        <di:waypoint x="300" y="220"/>
        <di:waypoint x="420" y="220"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToCallCar_di" bpmnElement="Flow_ToCallCar">
        <di:waypoint x="520" y="220"/>
        <di:waypoint x="640" y="220"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToEndSuccess_di" bpmnElement="Flow_ToEndSuccess">
        <di:waypoint x="740" y="220"/>
        <di:waypoint x="822" y="220"/>
      </bpmndi:BPMNEdge>

      <!-- ===== EDGES: Flight failure ===== -->
      <bpmndi:BPMNEdge id="Flow_FlightFailed_di" bpmnElement="Flow_FlightFailed">
        <di:waypoint x="250" y="278"/>
        <di:waypoint x="250" y="370"/>
      </bpmndi:BPMNEdge>

      <!-- ===== EDGES: Hotel failure → Cancel Flight → End ===== -->
      <bpmndi:BPMNEdge id="Flow_HotelFailed_di" bpmnElement="Flow_HotelFailed">
        <di:waypoint x="470" y="278"/>
        <di:waypoint x="470" y="350"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToEndHotelFailed_di" bpmnElement="Flow_ToEndHotelFailed">
        <di:waypoint x="520" y="390"/>
        <di:waypoint x="582" y="390"/>
      </bpmndi:BPMNEdge>

      <!-- ===== EDGES: Car failure → Cancel Hotel → Cancel Flight → End ===== -->
      <bpmndi:BPMNEdge id="Flow_CarFailed_di" bpmnElement="Flow_CarFailed">
        <di:waypoint x="690" y="278"/>
        <di:waypoint x="690" y="330"/>
        <di:waypoint x="750" y="330"/>
        <di:waypoint x="750" y="350"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToCancelFlight_FromCar_di" bpmnElement="Flow_ToCancelFlight_FromCar">
        <di:waypoint x="750" y="430"/>
        <di:waypoint x="750" y="490"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToEndCarFailed_di" bpmnElement="Flow_ToEndCarFailed">
        <di:waypoint x="800" y="530"/>
        <di:waypoint x="872" y="530"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
